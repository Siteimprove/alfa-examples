{
  "$schema": "../../node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": { "packageManager": "yarn" },
  "newProjectRoot": ".",
  "projects": {
    "button": {
      "projectType": "library",
      "root": ".",
      "sourceRoot": ".",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "development": { "tsConfig": "button/tsconfig.lib.json" }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "setupFiles": ["setup.ts"],
            "tsConfig": "button/tsconfig.spec.json"
          }
        }
      }
    }
  }
}
